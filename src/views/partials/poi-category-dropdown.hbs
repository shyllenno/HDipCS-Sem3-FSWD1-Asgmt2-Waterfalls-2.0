<div class="select is-fullwidth">
  <select id="POICategoryDropdown" name="POICategory" required>
    <option value="">Select a category</option>

    <!-- Waterfall-Specific -->
    <optgroup label="Waterfall-Specific">
      <option value="Waterfall Viewpoint" data-group="Waterfall-Specific">Waterfall Viewpoint</option>
      <option value="Swimming Allowed" data-group="Waterfall-Specific">Swimming Allowed</option>
      <option value="Danger Zone" data-group="Waterfall-Specific">Danger Zone</option>
      <option value="Best Season to Visit" data-group="Waterfall-Specific">Best Season to Visit</option>
      <option value="Drone-Friendly Area" data-group="Waterfall-Specific">Drone-Friendly Area</option>
      <option value="Drone-Restricted Area" data-group="Waterfall-Specific">Drone-Restricted Area
      </option>
      <option value="Accessibility Rating" data-group="Waterfall-Specific">Accessibility Rating</option>
    </optgroup>

    <!-- Nature & Outdoor Facilities -->
    <optgroup label="Nature & Outdoor">
      <option value="Hiking Trail" data-group="Nature & Outdoor">Hiking Trail</option>
      <option value="Scenic Viewpoint" data-group="Nature & Outdoor">Scenic Viewpoint</option>
      <option value="Picnic Area" data-group="Nature & Outdoor">Picnic Area</option>
      <option value="Camping Site" data-group="Nature & Outdoor">Camping Site</option>
      <option value="Swimming Spot" data-group="Nature & Outdoor">Swimming Spot</option>
    </optgroup>

    <!-- Safety & Emergency -->
    <optgroup label="Safety & Emergency">
      <option value="Weather Shelter" data-group="Safety & Emergency">Weather Shelter</option>
      <option value="Emergency Phone / SOS Point" data-group="Safety & Emergency">Emergency Phone / SOS Point
      </option>
      <option value="Ranger Station / Mountain Rescue" data-group="Safety & Emergency">Ranger Station /
        Mountain Rescue</option>
      <option value="Police Station" data-group="Safety & Emergency">Police Station</option>
      <option value="Fire Station" data-group="Safety & Emergency">Fire Station</option>
      <option value="Hospital" data-group="Safety & Emergency">Hospital</option>
    </optgroup>

    <!-- Food & Drink -->
    <optgroup label="Food & Drink">
      <option value="Restaurant" data-group="Food & Drink">Restaurant</option>
      <option value="Café" data-group="Food & Drink">Café</option>
      <option value="Pub / Bar" data-group="Food & Drink">Pub / Bar</option>
    </optgroup>

    <!-- Accommodation -->
    <optgroup label="Accommodation">
      <option value="Hotel" data-group="Accommodation">Hotel</option>
      <option value="Hostel" data-group="Accommodation">Hostel</option>
      <option value="Guesthouse / B&B" data-group="Accommodation">Guesthouse / B&B</option>
      <option value="Campsite" data-group="Accommodation">Campsite</option>
      <option value="Caravan / RV Park" data-group="Accommodation">Caravan / RV Park</option>
    </optgroup>

    <!-- Shops & Services -->
    <optgroup label="Shops & Services">
      <option value="Convenience Store" data-group="Shops & Services">Convenience Store</option>
      <option value="Petrol Station" data-group="Shops & Services">Petrol Station</option>
      <option value="ATM / Bank" data-group="Shops & Services">ATM / Bank</option>
      <option value="Post Office" data-group="Shops & Services">Post Office</option>
    </optgroup>

    <!-- Transport & Access -->
    <optgroup label="Transport & Access">
      <option value="Bus Stop" data-group="Transport & Access">Bus Stop</option>
      <option value="Train Station" data-group="Transport & Access">Train Station</option>
      <option value="Car Park" data-group="Transport & Access">Car Park</option>
    </optgroup>

    <!-- Attractions & Activities -->
    <optgroup label="Attractions & Activities">
      <option value="Museum" data-group="Attractions & Activities">Museum</option>
      <option value="Historical Site" data-group="Attractions & Activities">Historical Site</option>
      <option value="Guided Tour" data-group="Attractions & Activities">Guided Tour</option>
      <option value="Boat Tour" data-group="Attractions & Activities">Boat Tour</option>
      </option>
    </optgroup>

    <!-- Public Facilities -->
    <optgroup label="Public Facilities">
      <option value="Public Toilet" data-group="Public Facilities">Public Toilet</option>
      <option value="Drinking Water Station" data-group="Public Facilities">Drinking Water Station</option>
      <option value="Waste Disposal / Recycling" data-group="Public Facilities">Waste Disposal / Recycling
      </option>
    </optgroup>

  </select>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const select = document.getElementById("POICategoryDropdown");
    const typeInput = document.getElementById("POICategoryType");
    const groupInput = document.getElementById("POICategoryGroup");

    select.addEventListener("change", () => {
      const selectedOption = select.options[select.selectedIndex];
      typeInput.value = selectedOption.value;
      groupInput.value = selectedOption.dataset.group;
    });
  })
</script>