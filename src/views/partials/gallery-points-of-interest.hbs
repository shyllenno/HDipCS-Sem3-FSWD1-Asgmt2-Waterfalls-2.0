{{#if waterfall.POIs}}
<div class="box">
  <h3 class="title is-5">Gallery</h3>

  <div class="columns is-multiline">
    {{#each waterfall.POIs}}
      {{#if img}}
      <div class="column is-one-quarter">
        <figure class="image is-128x128">
          <img 
            src="{{img}}" 
            alt="{{type}}"
            class="gallery-thumb"
            data-full="{{img}}"
            style="width: 100%; height: 100%; object-fit: cover; border-radius: 6px; cursor: pointer;"
          >
        </figure>
      </div>
      {{/if}}
    {{/each}}
  </div>
</div>
{{/if}}
