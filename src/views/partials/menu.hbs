<nav class="navbar" role="navigation" aria-label="main navigation">
  <div class="navbar-brand">
    {{> waterfall-brand}}

    <!-- Mobile burger -->
    <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navMenu">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </a>
  </div>

  <div id="navMenu" class="navbar-menu">
    <div class="navbar-end">
      <div class="navbar-item">
        <div class="buttons">
          <a class="button" id="dashboard" href="/dashboard">Dashboard</a>
          <a class="button" id="logout" href="/logout">Logout</a>
          {{!-- <a id="about" class="button" href="/about"> About </a> --}}
          <a class="button" id="documentation" href="/documentation">API</a>
          <a id="user-profile" class="button" href="/userprofile" aria-label="User Profile button">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 20 20" aria-hidden="true">
              <path fill="currentColor"
                d="M9.993 10.573a4.5 4.5 0 1 0 0-9a4.5 4.5 0 0 0 0 9ZM10 0a6 6 0 0 1 3.04 11.174c3.688 1.11 6.458 4.218 6.955 8.078c.047.367-.226.7-.61.745c-.383.045-.733-.215-.78-.582c-.54-4.19-4.169-7.345-8.57-7.345c-4.425 0-8.101 3.161-8.64 7.345c-.047.367-.397.627-.78.582c-.384-.045-.657-.378-.61-.745c.496-3.844 3.281-6.948 6.975-8.068A6 6 0 0 1 10 0Z" />
            </svg>
          </a>

        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const burger = document.querySelector('.navbar-burger');
    const menu = document.getElementById(burger.dataset.target);

    burger.addEventListener('click', () => {
      burger.classList.toggle('is-active');
      menu.classList.toggle('is-active');
    });

    // Highlight active button
    const active = "{{active}}";
    if (active) {
      const el = document.getElementById(active);
      if (el) el.classList.add("is-primary");
    }
  });
</script>